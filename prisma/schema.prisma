generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String    @unique
  phoneNum  Int       @unique
  role      Role
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  Post Announcement[]
}

//model accountInformation {
  //id
//}

enum Role {
  CLIENT
  COACH
  ADMIN
}

model Announcement {

  id        String      @id @default(uuid())
  author User @relation(fields: [authorid], references: [id])
  authorid String
  createdAt DateTime

}
